{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "Allow SSL Requests Only",
			"Principal": "*",
			"Effect": "Deny",
			"Action": [
				"s3:*"
			],
			"Resource": [
				"arn:aws:s3:::documentbucket-aci1",
				"arn:aws:s3:::documentbucket-aci1/*"
			],
			"Condition": {
				"Bool": {
					"aws:SecureTransport": "false"
				}
			}
		}
	]
}